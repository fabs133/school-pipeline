{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ArtifactOutput",
  "type": "object",
  "required": ["file_path", "artifact_type"],
  "properties": {
    "file_path": { "type": "string" },
    "artifact_type": { "type": "string", "enum": ["pptx", "docx", "md", "project"] },
    "page_count": { "type": "integer", "minimum": 1 },
    "validation": {
      "type": "object",
      "properties": {
        "has_title": { "type": "boolean" },
        "section_count_matches": { "type": "boolean" },
        "no_placeholder_text": { "type": "boolean" },
        "file_size_bytes": { "type": "integer" }
      }
    }
  }
}
