{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ResearchOutput",
  "type": "object",
  "required": ["sections"],
  "properties": {
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["section_id", "findings", "sufficient"],
        "properties": {
          "section_id": { "type": "string" },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["content", "source"],
              "properties": {
                "content": { "type": "string" },
                "source": { "type": "string" },
                "relevance": { "type": "number", "minimum": 0, "maximum": 1 }
              }
            }
          },
          "sufficient": { "type": "boolean" }
        }
      }
    }
  }
}
