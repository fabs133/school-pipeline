{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AmendmentsOutput",
  "type": "object",
  "required": ["amendments"],
  "properties": {
    "amendments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "resolves", "decision", "reasoning"],
        "properties": {
          "id": { "type": "string" },
          "resolves": { "type": "string" },
          "finding_title": { "type": "string" },
          "decision": { "type": "string" },
          "reasoning": { "type": "string" },
          "source": { "type": "string" },
          "alternatives_considered": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "unresolvable": { "type": "array" },
    "all_clear": { "type": "boolean" }
  }
}
