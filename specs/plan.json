{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PlanOutput",
  "type": "object",
  "required": ["title", "artifact_type", "sections"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 3
    },
    "artifact_type": {
      "type": "string",
      "enum": ["pptx", "docx", "md", "project"]
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "purpose"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "purpose": { "type": "string" },
          "research_queries": {
            "type": "array",
            "items": { "type": "string" }
          },
          "estimated_length": {
            "type": "string",
            "enum": ["short", "medium", "long"]
          }
        }
      }
    },
    "style_notes": { "type": "string" }
  }
}
