{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SynthesisOutput",
  "type": "object",
  "required": ["title", "sections"],
  "properties": {
    "title": { "type": "string", "minLength": 3 },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["section_id", "heading", "content"],
        "properties": {
          "section_id": { "type": "string" },
          "heading": { "type": "string" },
          "content": { "type": "string", "minLength": 10 },
          "bullet_points": {
            "type": "array",
            "items": { "type": "string" }
          },
          "speaker_notes": { "type": ["string", "null"] },
          "visuals": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "intent"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["diagram", "photo", "icon", "chart", "screenshot", "logo"]
                },
                "intent": { "type": "string" },
                "placement": {
                  "type": "string",
                  "enum": ["right", "center"]
                },
                "search_hint": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
